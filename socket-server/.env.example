APP_ENV=local
SOCKET_PORT=6001
SOCKET_HOST=127.0.0.1
SOCKET_SERVER_SECRET=change-me-to-match-laravel-env
APP_URL=http://127.0.0.1:8000
SOCKET_SERVER_URL=http://127.0.0.1:6001

# Production — set in socket-server/.env on the server:
# APP_ENV=production
# SOCKET_HOST=0.0.0.0
# APP_URL=https://your-domain.com
# SOCKET_SERVER_URL=https://your-domain.com:6001
# SOCKET_SSL_KEY=/path/to/privkey.pem
# SOCKET_SSL_CERT=/path/to/fullchain.pem
