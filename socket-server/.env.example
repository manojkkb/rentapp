# Local
APP_ENV=local
SOCKET_PORT=6001
SOCKET_HOST=127.0.0.1
SOCKET_SERVER_SECRET=change-me-to-match-laravel-env
APP_URL=http://127.0.0.1:8000
SOCKET_SERVER_URL=http://127.0.0.1:6001

# Live (https://rentkia.com) — Node on 127.0.0.1:6001 + deploy/nginx-socket.conf.example on nginx
# APP_ENV=production
# APP_URL=https://rentkia.com
# SOCKET_SERVER_URL=https://rentkia.com
# SOCKET_SERVER_SECRET=same-as-laravel-SOCKET_SERVER_SECRET

# Optional: direct HTTPS on port 6001 (open firewall; set SOCKET_HOST=0.0.0.0)
# SOCKET_SSL_KEY=/etc/letsencrypt/live/rentkia.com/privkey.pem
# SOCKET_SSL_CERT=/etc/letsencrypt/live/rentkia.com/fullchain.pem
