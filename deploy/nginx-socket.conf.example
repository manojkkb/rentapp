# Add inside your https://rentkia.com server { } block (after SSL is configured).
# Node socket server: pm2 on 127.0.0.1:6001 (APP_ENV=production, no SOCKET_SSL_* needed).

location /socket.io/ {
    proxy_pass http://127.0.0.1:6001/socket.io/;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 86400;
}

location /internal/broadcast {
    allow 127.0.0.1;
    deny all;
    proxy_pass http://127.0.0.1:6001/internal/broadcast;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
}
