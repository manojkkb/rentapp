APP_NAME=Rentkia
# Vendor PWA label (install prompt / home screen); optional — defaults to Rentkia App
# VENDOR_PWA_NAME="Rentkia App"
# VENDOR_PWA_SHORT_NAME="Rentkia App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rentapp
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Mobile API (Sanctum bearer token)
# Base URL: https://rentkia.com/api/v1
# Auth: Authorization: Bearer {token}

# Vendor support chat (Socket.IO — direct HTTPS on Node port 6001)
SOCKET_SERVER_URL=http://127.0.0.1:6001
SOCKET_BROADCAST_URL=http://127.0.0.1:6001/internal/broadcast
# Live https://rentkia.com — open firewall TCP 6001; same SOCKET_SERVER_SECRET in socket-server/.env
# APP_URL=https://rentkia.com
# SOCKET_SERVER_URL=https://rentkia.com:6001
# SOCKET_BROADCAST_URL=http://127.0.0.1:6002/internal/broadcast
# SOCKET_BROADCAST_PORT=6002
# SOCKET_SERVER_SECRET=long-random-string
SOCKET_SERVER_SECRET=
SOCKET_PORT=6001
